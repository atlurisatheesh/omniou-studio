# ═══════════════════════════════════════════════════════════════════════════════
# CLONEAI ULTRA — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Generate secrets:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ═══════════════════════════════════════════════════════════════════════════════

# ── APP ──────────────────────────────────────────────────────────────────────
APP_NAME=CloneAI Ultra
APP_ENV=development                    # development | production
APP_DEBUG=true                         # Set false in production
API_URL=http://localhost:8000          # Backend API URL
APP_URL=http://localhost:3000          # Frontend URL

# ── DATABASE ─────────────────────────────────────────────────────────────────
# Development (SQLite — no setup needed, auto-created):
DATABASE_URL=sqlite+aiosqlite:///./cloneai_dev.db

# Production (PostgreSQL — uncomment and configure):
# DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/cloneai
POSTGRES_DB=cloneai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── REDIS ─────────────────────────────────────────────────────────────────────
# Required for Celery (background jobs) and WebSocket progress pub/sub.
# In dev mode without Redis, jobs run synchronously.
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ── MINIO STORAGE ─────────────────────────────────────────────────────────────
# S3-compatible object storage. Set USE_MINIO=false for local filesystem.
USE_MINIO=false                        # true = MinIO, false = local filesystem
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=cloneai-files
MINIO_USE_SSL=false                    # true in production with SSL

# ── AUTH / JWT ───────────────────────────────────────────────────────────────
# IMPORTANT: Change this in production! Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080      # 7 days (60 * 24 * 7)

# ── NEXTAUTH (Frontend) ──────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=GENERATE_ANOTHER_32_CHAR_RANDOM_STRING
# Generate with: openssl rand -base64 32

# ── GOOGLE OAUTH (optional) ──────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI ENGINE SELECTION ───────────────────────────────────────────────────────
# Voice: "auto" routes English→Chatterbox, non-English→XTTS v2
VOICE_ENGINE=auto                      # auto | chatterbox | xtts
CHATTERBOX_MODEL=resemble-ai/chatterbox
XTTS_MODEL_NAME=tts_models/multilingual/multi-dataset/xtts_v2

# Face animation engine
FACE_ENGINE=liveportrait               # liveportrait | basic

# Lip synchronization engine
LIPSYNC_ENGINE=musetalk                # musetalk | latentsync | basic

# Face enhancement engine
ENHANCE_ENGINE=gfpgan                  # gfpgan | realesrgan | basic

# ── GPU SETTINGS ─────────────────────────────────────────────────────────────
DEVICE=cuda                            # cuda | cpu (use "cpu" if no GPU)
CUDA_VISIBLE_DEVICES=0                 # Which GPU (0 = first GPU)
GPU_MEMORY_FRACTION=0.8                # Max GPU memory usage (0.0-1.0)

# ── MODEL / FILE PATHS ───────────────────────────────────────────────────────
MODEL_CACHE_DIR=./models               # AI model weights cache (~4GB)

# ── POST-PROCESSING (7-layer cinematic pipeline) ─────────────────────────────
# Each layer is independently togglable. All enabled = maximum anti-detection.
ENABLE_MICROJITTER=true                # Sub-pixel random translation (±2px)
ENABLE_FILM_GRAIN=true                 # Luminance-aware sensor noise
ENABLE_LENS_DISTORTION=true            # Barrel distortion (real lens simulation)
ENABLE_DOF=true                        # Depth-of-field (face sharp, BG bokeh)
ENABLE_COLOR_GRADE=true                # Cinematic color grading (warm/cool)
ENABLE_AUDIO_POST=true                 # Room acoustics, EQ, loudnorm
GRAIN_INTENSITY=0.08                   # 0.0-0.2 (0.08 = optimal, imperceptible)
JITTER_MAX_PX=2.0                      # Max pixel displacement (2.0 = imperceptible)

# ── QUALITY GATES ─────────────────────────────────────────────────────────────
# 3-gate validation system. All gates must pass for clean delivery.
SYNCNET_MIN_SCORE=7.0                  # Lip-audio sync minimum (0-10, ≥7.0 = good)
FACE_SIMILARITY_MIN=0.60               # Identity preservation minimum (0-1.0, ≥0.6 = match)
AI_DETECT_MAX_PCT=30.0                 # AI detection max percentage (0-100, ≤30 = undetectable)

# ── SCRIPT AI (Ollama) ───────────────────────────────────────────────────────
# Local LLM for AI script generation. Falls back to templates if unavailable.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── RATE LIMITING & QUOTAS ───────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=10               # Max clone requests per user per minute
MAX_UPLOAD_SIZE_MB=50                  # Max file upload size
MAX_VIDEO_DURATION_SECONDS=300         # Max 5 minute videos
FREE_MONTHLY_LIMIT=5                   # Free plan: 5 videos/month
PRO_MONTHLY_LIMIT=9999                 # Pro plan: unlimited

# ── FILE RETENTION ────────────────────────────────────────────────────────────
FACE_RETENTION_HOURS=24                # Delete uploaded faces after 24h
VIDEO_RETENTION_DAYS=30                # Keep generated videos for 30 days

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
