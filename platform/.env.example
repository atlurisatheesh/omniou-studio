# Ominou Studio Platform

## Environment
NODE_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:8080

## JWT
JWT_SECRET=ominou-studio-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

## Database
DATABASE_URL=sqlite+aiosqlite:///./ominou_studio.db

## AI API Keys (add your keys here)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# STABILITY_API_KEY=sk-...
# ELEVENLABS_API_KEY=...
# REPLICATE_API_TOKEN=...

## Stripe (add your keys here)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

## Service Ports
AUTH_PORT=8001
VOICE_PORT=8002
DESIGN_PORT=8003
CODE_PORT=8004
VIDEO_PORT=8005
WRITER_PORT=8006
MUSIC_PORT=8007
WORKFLOW_PORT=8008
BILLING_PORT=8009
GATEWAY_PORT=8080
FRONTEND_PORT=3001
